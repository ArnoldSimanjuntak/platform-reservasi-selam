# =============================================
# SulutDive Environment Variables
# Copy this file to .env.local (local) and Vercel Environment Variables (cloud)
# =============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL (recommended for auth redirects / canonical URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (required for push notification)
# Generate one key pair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your-email@example.com
